{
  "name": "@circle-fin/swap-kit",
  "version": "1.4.0",
  "description": "A Circle SDK for single-chain token swaps with minimal code",
  "keywords": [
    "circle",
    "circle-fin",
    "usdc",
    "stablecoin",
    "sdk",
    "typescript",
    "swap-kit",
    "swap",
    "stablecoin-swap",
    "token-swap",
    "usdc-swapping",
    "usdt",
    "dai",
    "evm",
    "non-evm",
    "solana",
    "usdc-sdk"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "./index.cjs",
  "module": "./index.mjs",
  "types": "./index.d.cts",
  "dependencies": {
    "zod": "3.25.67",
    "@circle-fin/provider-stablecoin-service-swap": "^1.3.0",
    "@coral-xyz/anchor": "^0.31.1",
    "bn.js": "^5.2.3",
    "abitype": "^1.1.0",
    "@solana/web3.js": "^1.98.4",
    "bs58": "6.0.0",
    "@noble/curves": "1.4.2",
    "@ethersproject/abi": "^5.8.0",
    "@ethersproject/address": "^5.8.0",
    "@ethersproject/bytes": "^5.8.0",
    "@ethersproject/units": "^5.8.0"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": {
        "import": "./index.d.mts",
        "require": "./index.d.cts"
      },
      "import": "./index.mjs",
      "require": "./index.cjs",
      "default": "./index.cjs"
    }
  },
  "files": [
    "index.*",
    "README.md",
    "CHANGELOG.md",
    "package.json",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false
}