{
  "name": "@circle-fin/bridge-kit",
  "version": "1.12.1",
  "description": "Official Circle SDK for seamless cross-chain USDC bridging",
  "keywords": [
    "circle",
    "circle-fin",
    "usdc",
    "stablecoin",
    "sdk",
    "typescript",
    "cctp",
    "cctpv2",
    "usdc-bridging",
    "stablecoin-bridging",
    "bridge",
    "bridging",
    "cross-chain",
    "usdc-sdk",
    "bridge-kit",
    "evm",
    "non-evm",
    "solana"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "./index.cjs",
  "module": "./index.mjs",
  "types": "./index.d.cts",
  "dependencies": {
    "zod": "3.25.67",
    "@circle-fin/provider-cctp-v2": "^1.10.0",
    "abitype": "^1.1.0",
    "@solana/web3.js": "^1.98.4",
    "@ethersproject/abi": "^5.8.0",
    "@ethersproject/address": "^5.8.0",
    "@ethersproject/bytes": "^5.8.0",
    "@ethersproject/units": "^5.8.0",
    "bs58": "6.0.0",
    "pino": "10.1.0"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": {
        "import": "./index.d.mts",
        "require": "./index.d.cts"
      },
      "import": "./index.mjs",
      "require": "./index.cjs",
      "default": "./index.cjs"
    },
    "./chains": {
      "types": {
        "import": "./chains.d.mts",
        "require": "./chains.d.cts"
      },
      "import": "./chains.mjs",
      "require": "./chains.cjs",
      "default": "./chains.cjs"
    }
  },
  "files": [
    "chains.*",
    "index.*",
    "README.md",
    "QUICKSTART.md",
    "CHANGELOG.md",
    "package.json",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false
}