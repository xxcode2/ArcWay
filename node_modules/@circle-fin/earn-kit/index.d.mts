     * a.formatted({ minimumFractionDigits: 2 }) // "1,000.50"
     * a.formatted({ useGrouping: false })       // "1000.5"
     * ```
     */
    formatted(options?: FormatOptions): string;
    /**
     * Convert to a human-readable string.
     *
     * @returns A formatted string like "1.5".
     *
