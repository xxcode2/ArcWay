     * @returns True if the raw value is less than 0n.
     *
     * @example
     * ```typescript
     * Amount.of(-1_000_000n, { decimals: 6 }).isNegative() // true
     * Amount.parse('1.0', { decimals: 6 }).isNegative() // false
     * ```
     */
    isNegative(): boolean;
    /**
     * Convert this Amount to a different decimal precision.
