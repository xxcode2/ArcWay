    fetchAttestation: CCTPV2ActionBase & {
        method: 'fetchAttestation';
        values: BridgeFetchAttestationStep;
    };
    /**
     * Mint action for CCTP v2 transfers.
     * Used to mint tokens on the destination chain after a successful burn.
