{
  "name": "@circle-fin/provider-stablecoin-service-swap",
  "version": "1.3.0",
  "description": "Swap provider for on-chain token swaps via Circle's stablecoin APIs",
  "keywords": [
    "circle",
    "circle-fin",
    "usdc",
    "stablecoin",
    "sdk",
    "typescript",
    "provider",
    "swap",
    "dex",
    "token-swap",
    "app-kit",
    "swap-kit"
  ],
  "main": "./index.cjs",
  "module": "./index.mjs",
  "types": "./index.d.cts",
  "dependencies": {
    "zod": "3.25.67",
    "@coral-xyz/anchor": "^0.31.1",
    "@ethersproject/address": "^5.8.0",
    "@ethersproject/bytes": "^5.8.0",
    "@ethersproject/units": "^5.8.0",
    "@noble/curves": "1.4.2",
    "bn.js": "^5.2.3",
    "bs58": "^6.0.0",
    "abitype": "^1.1.0",
    "@solana/web3.js": "^1.98.4"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": {
        "import": "./index.d.mts",
        "require": "./index.d.cts"
      },
      "import": "./index.mjs",
      "require": "./index.cjs",
      "default": "./index.cjs"
    }
  },
  "files": [
    "index.*",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  }
}