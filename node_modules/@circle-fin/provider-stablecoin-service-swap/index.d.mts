 *     recipientAddress: '0x742d35Cc6634C0532925a3b844Bc9e7595f0bEb0'
 *   }
 * }
 * ```
 *
 * @example
 * ```typescript
 * // No custom fee (default behavior)
 * const configNoFee: StablecoinServiceSwapProviderConfig = {}
 * ```
 */
