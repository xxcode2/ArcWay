    /**
     * Optional developer fee configuration applied to the swap.
     *
     * @remarks
     * Allows collecting a custom fee on each swap operation. The fee is taken
     * from the swap amount and sent to the specified recipient address.
     */
    readonly customFee?: {
        /**
         * Custom fee amount to collect in base units (stringified bigint).
         *
         * @example '1000000' for 1 USDC fee (6 decimals)
         */
        readonly amount: string;
        /**
         * Wallet address that receives the custom fee.
         *
         * @example '0x742d35Cc6634C0532925a3b844Bc9e7595f0bEb0'
         */
        readonly recipientAddress: string;
    };
}
