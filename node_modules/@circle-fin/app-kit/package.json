{
  "name": "@circle-fin/app-kit",
  "version": "1.10.0",
  "description": "A one-stop Circle SDK solution for building stablecoin (e.g. USDC) applications, with bridging, swapping, and more on-chain operations",
  "keywords": [
    "circle",
    "circle-fin",
    "usdc",
    "stablecoin",
    "sdk",
    "typescript",
    "swap-kit",
    "swap",
    "stablecoin-swap",
    "token-swap",
    "usdc-swapping",
    "bridge",
    "bridging",
    "cross-chain",
    "cctp",
    "cctpv2",
    "usdc-bridging",
    "stablecoin-payment",
    "usdt",
    "dai",
    "evm",
    "non-evm",
    "solana",
    "app-kit",
    "bridge-kit"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "./index.cjs",
  "module": "./index.mjs",
  "types": "./index.d.cts",
  "dependencies": {
    "@circle-fin/unified-balance-kit": "1.3.0",
    "@circle-fin/provider-gateway-v1": "1.1.3",
    "@circle-fin/earn-kit": "1.3.0",
    "@circle-fin/bridge-kit": "1.12.1",
    "@circle-fin/swap-kit": "1.4.0",
    "@coral-xyz/anchor": "^0.31.1",
    "@noble/curves": "1.4.2",
    "bn.js": "^5.2.3",
    "@ethersproject/keccak256": "^5.8.0",
    "pino": "10.1.0",
    "zod": "3.25.67",
    "@ethersproject/abi": "^5.8.0",
    "@ethersproject/address": "^5.8.0",
    "@ethersproject/bytes": "^5.8.0",
    "@ethersproject/units": "^5.8.0",
    "bs58": "6.0.0",
    "abitype": "^1.1.0",
    "@solana/web3.js": "^1.98.4"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": {
        "import": "./index.d.mts",
        "require": "./index.d.cts"
      },
      "import": "./index.mjs",
      "require": "./index.cjs",
      "default": "./index.cjs"
    },
    "./chains": {
      "types": {
        "import": "./chains.d.mts",
        "require": "./chains.d.cts"
      },
      "import": "./chains.mjs",
      "require": "./chains.cjs",
      "default": "./chains.cjs"
    },
    "./context": {
      "types": {
        "import": "./context.d.mts",
        "require": "./context.d.cts"
      },
      "import": "./context.mjs",
      "require": "./context.cjs"
    },
    "./bridge": {
      "types": {
        "import": "./bridge.d.mts",
        "require": "./bridge.d.cts"
      },
      "import": "./bridge.mjs",
      "require": "./bridge.cjs"
    },
    "./estimateBridge": {
      "types": {
        "import": "./estimateBridge.d.mts",
        "require": "./estimateBridge.d.cts"
      },
      "import": "./estimateBridge.mjs",
      "require": "./estimateBridge.cjs"
    },
    "./swap": {
      "types": {
        "import": "./swap.d.mts",
        "require": "./swap.d.cts"
      },
      "import": "./swap.mjs",
      "require": "./swap.cjs"
    },
    "./earn": {
      "types": {
        "import": "./earn.d.mts",
        "require": "./earn.d.cts"
      },
      "import": "./earn.mjs",
      "require": "./earn.cjs"
    },
    "./estimateSwap": {
      "types": {
        "import": "./estimateSwap.d.mts",
        "require": "./estimateSwap.d.cts"
      },
      "import": "./estimateSwap.mjs",
      "require": "./estimateSwap.cjs"
    },
    "./unifiedBalance": {
      "types": {
        "import": "./unifiedBalance.d.mts",
        "require": "./unifiedBalance.d.cts"
      },
      "import": "./unifiedBalance.mjs",
      "require": "./unifiedBalance.cjs"
    }
  },
  "files": [
    "chains.*",
    "context.*",
    "bridge.*",
    "estimateBridge.*",
    "swap.*",
    "estimateSwap.*",
    "unifiedBalance.*",
    "earn.*",
    "index.*",
    "README.md",
    "QUICKSTART.md",
    "CHANGELOG.md",
    "package.json",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false
}